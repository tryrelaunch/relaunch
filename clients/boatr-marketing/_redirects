# Public URL spec: previews live at /preview/[slug]/ (singular).
# Repo folder stays /previews/ (plural). Rewrite keeps /preview/... in browser,
# serves content from /previews/...

# Common Disco Boat typo URLs — redirect to the canonical slug + trailing slash
# so relative image paths resolve correctly. Listed BEFORE the generic /preview/*
# rewrite so they fire first.
/preview/discoboatrental.com    /preview/disco-boat-rental/   301
/preview/discoboatrental.com/   /preview/disco-boat-rental/   301
/preview/discoboatrentals.com   /preview/disco-boat-rental/   301
/preview/discoboatrentals.com/  /preview/disco-boat-rental/   301

# Force trailing slash on canonical Disco Boat URLs (relative img paths break without it)
/preview/disco-boat-rental                                       /preview/disco-boat-rental/   301
/preview/disco-boat-rental/the-boat                              /preview/disco-boat-rental/the-boat/   301
/preview/disco-boat-rental/bachelorette-party-boat-san-diego     /preview/disco-boat-rental/bachelorette-party-boat-san-diego/   301
/preview/disco-boat-rental/articles                              /preview/disco-boat-rental/articles/   301
/preview/disco-boat-rental/disco-party-planning-guide            /preview/disco-boat-rental/disco-party-planning-guide/   301
/preview/disco-boat-rental/boat-rental-mission-bay               /preview/disco-boat-rental/boat-rental-mission-bay/   301

/preview/*   /previews/:splat   200!

# Admin editor — rewrites to / with ?admin=1 so the editor unlocks PIN gate.
/admin       /?admin=1   200
/admin/      /?admin=1   200
/admin/*     /?admin=1   200
/edit        /?admin=1   200
/edit/       /?admin=1   200
/edit/*      /?admin=1   200
